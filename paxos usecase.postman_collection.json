							"",
							"// Set environment variable with the access token",
							"if (jsonData.access_token) {",
							"    pm.environment.set(\"paxos_api_token\", jsonData.access_token);",
							"    console.log(\"Paxos token updated:\", jsonData.access_token);",
							"} else {",
							"    console.warn(\"No access token found in response.\");",
							"}"
